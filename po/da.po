#: core/Services/CalDAV/CalDAVClient.vala:776
msgid ""
"This server does not allow creating projects via CalDAV. Please create it "
"directly from your calendar provider's website."
msgstr ""
"Serveren tillader ikke oprettelse af projekter via CalDAV. Opret venligst "
"projekter på den hjemmeside, hvor din kalender ligger."

#: core/Services/CalDAV/CalDAVClient.vala:828
msgid ""
"This server does not allow deleting projects via CalDAV. Please delete it "
"directly from your calendar provider's website."
msgstr ""
"Serveren tillader ikke sletning af projekter via CalDAV. Slet venligst "
"projekter på den hjemmeside, hvor din kalender ligger."

#: core/Services/CalDAV/CalDAVClient.vala:832
msgid ""
"This server does not support deleting projects via CalDAV. Please delete it "
"from the server directly."
msgstr ""
"Serveren tillader ikke sletning af projekter igennem CalDAV. Projektet skal "
"slettes direkte på serveren."

#: core/Services/CalDAV/CalDAVClient.vala:866
#: core/Services/CalDAV/CalDAVClient.vala:913
msgid ""
"Task was modified on another device. Please sync to get the latest version."
msgstr ""
"Opgaven blev ændret på en anden enhed. Synkroniser for at få de seneste "
"ændringer."

#: core/Services/CalDAV/Core.vala:170
msgid "Source already exists"
msgstr "Kilden findes allerede"

#: core/Services/CalDAV/Core.vala:181 core/Services/CalDAV/Core.vala:229
